---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/about.scss';
---
<BaseLayout title="About - Volleier" showNav={false} showFooter={false}>
  <main class="about-container">
    <!-- Clean Minimal HUD -->
    <div class="serif serif-top"></div>
    <div class="serif serif-bottom"></div>
    <div class="serif serif-left"></div>
    <div class="serif serif-right"></div>
    
    <div class="content-grid">
      <!-- Left Panel: Profile -->
      <aside class="profile-panel">
        <div class="profile-card">
          <div class="avatar-container">
            <img src="/assets/about/avatar.png" alt="Volleier Avatar" class="avatar-img" />
            <div class="avatar-accent"></div>
          </div>
          
          <div class="identity-header">
            <h1 class="subject-name">VOLLEIER</h1>
            <span class="subject-id">ID.VLR_RESUME_SYNC</span>
          </div>

          <div class="identity-stats">
            <div class="stat-item">
              <span class="label">STATUS.</span>
              <span class="value cyan">ACTIVE</span>
            </div>
            <div class="stat-item">
              <span class="label">MAIL.</span>
              <span class="value">Volleiershao@gmail.com</span>
            </div>
          </div>
        </div>
        
        <a href="/default" class="flat-button">
          <span class="btn-tag">00</span>
          <span class="btn-text">RETURN_HOME</span>
        </a>
      </aside>

      <!-- Right Panel: Info -->
      <section class="info-panel">
        <!-- Bio / Core -->
        <div class="info-card primary">
          <div class="card-accent magenta"></div>
          <header class="card-header">
            <span class="tag">01_CORE_PROTOCOL</span>
            <h2>核心协议 / CORE</h2>
          </header>
          <div class="card-body">
            <p>
              我是 Volleier，一名深耕于<b>虚幻引擎底层架构</b>与<b>人工智能算法</b>的跨界开发者。我主张将严谨的工业逻辑与极简的平面艺术结合，在 `C++` 的高性能世界与 `AI` 的前沿研究中构建未来。目前专注于探索高性能多人联机逻辑与神经渲染技术（NPR）。
            </p>
          </div>
        </div>

        <!-- Skills / Spec -->
        <div class="info-card">
          <div class="card-accent cyan"></div>
          <header class="card-header">
            <span class="tag">02_TECH_SPEC</span>
            <h2>技术指标 / SPEC</h2>
          </header>
          <div class="card-body skill-list">
            <div class="skill-row">
              <div class="skill-name">ENGINE_DEV (UE/C++)</div>
              <div class="skill-bar-container">
                <div class="skill-bar" style="width: 95%"></div>
              </div>
            </div>
            <div class="skill-row">
              <div class="skill-name">AI_ALGO (CV/LLM)</div>
              <div class="skill-bar-container">
                <div class="skill-bar" style="width: 90%"></div>
              </div>
            </div>
            <div class="skill-row">
              <div class="skill-name">ART_TECH (BLENDER)</div>
              <div class="skill-bar-container">
                <div class="skill-bar" style="width: 82%"></div>
              </div>
            </div>
            <div class="skill-row">
              <div class="skill-name">FULL_STACK (JV/TS)</div>
              <div class="skill-bar-container">
                <div class="skill-bar" style="width: 88%"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Achievements / Achievement -->
         <div class="info-card">
          <div class="card-accent gold"></div>
          <header class="card-header">
            <span class="tag">03_ACHIEVEMENT</span>
            <h2>荣誉与成果 / ARCHIVE</h2>
          </header>
          <div class="card-body achievement-list">
            <div class="achieve-item">
                <span class="achieve-type">PAPER</span>
                <p>3x SCI一区论文 (Nature Comm. / Nano Energy)</p>
            </div>
            <div class="achieve-item">
                <span class="achieve-type">AWARD</span>
                <p>CUSGA 游戏大赛决赛入围</p>
            </div>
            <div class="achieve-item">
                <span class="achieve-type">AWARD</span>
                <p>吉比特 48h 游戏开发赛 - 最佳潜力奖</p>
            </div>
          </div>
        </div>

        <!-- Project / Project -->
        <div class="info-card">
          <div class="card-accent white"></div>
          <header class="card-header">
            <span class="tag">04_PROJECT_LOG</span>
            <h2>项目记录 / PROJECT</h2>
          </header>
          <div class="card-body project-grid">
            <div class="project-item">
                <div class="item-head">BLASTER_TPS</div>
                <p>基于 UE C++ 的多人联机射击游戏原型 (RPC/GAS)</p>
            </div>
            <div class="project-item">
                <div class="item-head">GAS_CARD_GAME</div>
                <div class="p">回合制卡牌架构实现，专注技能表现与数据处理</div>
            </div>
            <div class="project-item">
                <div class="item-head">CLOCK_GOBLIN</div>
                <p>C# 开源软件使用时长追踪分析工具</p>
            </div>
          </div>
        </div>

        <!-- Link -->
        <div class="info-card">
          <div class="card-accent transparent"></div>
          <header class="card-header">
            <span class="tag">05_COMM_LINK</span>
            <h2>通讯链路 / LINK</h2>
          </header>
          <div class="card-body contact-links">
            <a href="#" class="contact-item">GITHUB.LINK</a>
            <a href="#" class="contact-item">PIXIV.LINK</a>
            <a href="#" class="contact-item">PORTFOLIO.SYNC</a>
          </div>
        </div>

      </section>
    </div>
  </main>
</BaseLayout>

