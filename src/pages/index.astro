---
import BaseLayout from '../layouts/BaseLayout.astro';
import FluidBackground from '../components/FluidBackground.astro';
---
<BaseLayout>
  <!-- 背景特效 -->
  <FluidBackground />

  <!-- 居中毛玻璃卡片 -->
  <main class="fixed inset-0 z-10 flex items-center justify-center">
    <div class="glass-card">
      <img src="/assets/PengLaiSiShaoXiao.png" alt="PengLaiSiShaoXiao Header Image" class="logo-img" />
    </div>
  </main>
</BaseLayout>

<style is:global>
  .glass-card {
    /* 尺寸 */
    width: clamp(480px, 80vw, 1440px);
    min-height: clamp(360px, 60vh, 960px);
    padding: 4.5rem 6rem;

    /* 无毛玻璃、无背景色：卡片内部直接穿透到清晰背景 */
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: transparent;

    /* 圆角 */
    border-radius: 32px;
    border: none;
    position: relative;
    isolation: isolate;

    box-shadow: none;

    /* 内部布局 */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 模糊边框：仅一条细白线，通过 filter:blur 虚化，无任何颜色填充 */
  .glass-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 32px;
    border: 1.5px solid rgba(255, 255, 255, 0);
    pointer-events: none;
    z-index: 1;
  }

  .logo-img {
    max-width: 100%;
    max-height: 480px;
    object-fit: contain;
    mix-blend-mode: screen;
    filter: drop-shadow(0 0 24px rgba(120, 200, 255, 0.25));
  }
</style>

