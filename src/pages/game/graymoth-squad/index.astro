---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/pages/graymoth-squad.scss';
---

<BaseLayout title="GrayMoth Squad - Volleier" showNav={false} showFooter={false} showLoading={false}>
  <div class="gm-container">
    <div class="gm-nav-top">
      <a href="/" class="return-link">
        <span class="lnr">←</span> SYS.RETURN_ROOT
      </a>
    </div>

    <main class="gm-content">
      <div class="gm-title-area">
        <h1 class="gm-logo-text">GrayMoth</h1>
        <p class="gm-subtitle">Squadron Protocol / Unit 04</p>
      </div>

      <aside class="gm-sidebar-right">
        <a href="#" class="gm-tech-button">
          <span class="btn-glow"></span>
          开始任务
        </a>
        <a href="#" class="gm-tech-button">
          <span class="btn-glow"></span>
          查看档案
        </a>
      </aside>
    </main>

    <div class="serif serif-top"></div>
    <div class="serif serif-bottom"></div>
    <div class="serif serif-left"></div>
    <div class="serif serif-right"></div>
  </div>
</BaseLayout>
