---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllBlogPosts, getBlogPostBySlug } from '../../domain/intro/queries';
import { formatDate } from '../../domain/shared/date';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  return posts.map((entry: any) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
const entry = await getBlogPostBySlug(slug as string);
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-3xl mx-auto py-10 prose prose-slate dark:prose-invert prose-headings:font-outfit lg:prose-xl">
    <div class="mb-10 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">{entry.data.title}</h1>
      <p class="text-slate-500 font-mono">
        Published on {formatDate(entry.data.publishDate)} • By {entry.data.author}
      </p>
    </div>
    <div class="glass-card p-8 sm:p-12 rounded-3xl mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>
