---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAboutCards } from '../../domain/about/queries';
import '../../styles/pages/about.scss';

const cards = await getAboutCards();
const renderedCards = await Promise.all(
  cards.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<BaseLayout title="About - Volleier" showNav={false} showFooter={false}>
  <main class="about-container" data-grid-size="24">
    <div class="canvas-viewport" id="about-canvas">
      <div class="dot-grid-layer"></div>

      <div class="canvas-content" id="about-canvas-content">
        {renderedCards.map(({ entry, Content }) => (
          <article
            class:list={['info-card', 'about-card', entry.data.className]}
            data-card
            data-x={entry.data.x}
            data-y={entry.data.y}
            style={`--card-grid-w:${entry.data.w};`}
          >
            <div class:list={['card-accent', entry.data.accent]}></div>
            <header class="card-header">
              <span class="tag">{entry.data.tag}</span>
              <h2>{entry.data.heading}</h2>
            </header>
            <div class="card-body markdown-body">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="serif serif-top"></div>
    <div class="serif serif-bottom"></div>
    <div class="serif serif-left"></div>
    <div class="serif serif-right"></div>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('.about-container');
      const viewport = document.getElementById('about-canvas');
      const canvas = document.getElementById('about-canvas-content');
      if (!root || !viewport || !canvas) return;

      const gridSize = Number(root.dataset.gridSize || 24);
      const cards = Array.from(canvas.querySelectorAll('[data-card]'));
      const state = {
        panX: window.innerWidth * 0.2,
        panY: window.innerHeight * 0.2,
        scale: 1,
      };

      const edge = {
        active: false,
        mouseX: 0,
        mouseY: 0,
        threshold: 72,
        speed: 18,
      };

      const drag = {
        card: null,
        pointerId: -1,
        startClientX: 0,
        startClientY: 0,
        startWorldX: 0,
        startWorldY: 0,
        startX: 0,
        startY: 0,
        dragging: false,
        mayDrag: false,
        armed: false,
        holdMs: 160,
        holdTimer: null,
        wasDragging: false,
      };

      const pan = {
        active: false,
        pointerId: -1,
        startX: 0,
        startY: 0,
        startPanX: 0,
        startPanY: 0,
        middlePressed: false,
      };

      const snap = (value) => Math.round(value / gridSize) * gridSize;
      const clampScale = (v) => Math.min(2.4, Math.max(0.45, v));

      const parseNum = (value, fallback = 0) => {
        const n = Number(value);
        return Number.isFinite(n) ? n : fallback;
      };

      const setCardPos = (card, x, y) => {
        card.dataset.x = String(x);
        card.dataset.y = String(y);
        card.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      };

      const refreshCardMetrics = (card) => {
        const width = Math.max(gridSize * 8, Math.ceil(card.offsetWidth / gridSize) * gridSize);
        const height = Math.max(gridSize * 8, Math.ceil(card.scrollHeight / gridSize) * gridSize);
        card.style.width = `${width}px`;
        card.style.minHeight = `${height}px`;
      };

      const render = () => {
        root.style.setProperty('--pan-x', `${state.panX}`);
        root.style.setProperty('--pan-y', `${state.panY}`);
        root.style.setProperty('--zoom', `${state.scale}`);
        canvas.style.transform = `translate3d(${state.panX}px, ${state.panY}px, 0) scale(${state.scale})`;
      };

      cards.forEach((card) => {
        refreshCardMetrics(card);
        const x = snap(parseNum(card.dataset.x));
        const y = snap(parseNum(card.dataset.y));
        setCardPos(card, x, y);
      });

      const clearHoldTimer = () => {
        if (drag.holdTimer !== null) {
          window.clearTimeout(drag.holdTimer);
          drag.holdTimer = null;
        }
      };

      const resetDragState = () => {
        clearHoldTimer();
        if (drag.card) {
          if (drag.pointerId !== -1 && drag.card.hasPointerCapture(drag.pointerId)) {
            drag.card.releasePointerCapture(drag.pointerId);
          }
          drag.card.classList.remove('is-armed');
          drag.card.classList.remove('is-dragging');
        }
        root.classList.remove('is-dragging-card');
        drag.card = null;
        drag.pointerId = -1;
        drag.dragging = false;
        drag.mayDrag = false;
        drag.armed = false;
      };

      const onCardDown = (ev) => {
        const target = ev.target;
        if (!(target instanceof HTMLElement)) return;
        if (ev.button !== 0) return;

        const card = target.closest('[data-card]');
        if (!card || !(card instanceof HTMLElement)) return;

        drag.card = card;
        drag.pointerId = ev.pointerId;
        drag.startClientX = ev.clientX;
        drag.startClientY = ev.clientY;
        drag.startWorldX = (ev.clientX - state.panX) / state.scale;
        drag.startWorldY = (ev.clientY - state.panY) / state.scale;
        drag.startX = parseNum(card.dataset.x);
        drag.startY = parseNum(card.dataset.y);
        drag.dragging = false;
        drag.mayDrag = true;
        drag.armed = false;
        drag.wasDragging = false;

        // Note: card.setPointerCapture is moved to onPointerMove to avoid interfering with 'click' events for links.

        drag.holdTimer = window.setTimeout(() => {
          if (!drag.mayDrag || !drag.card || drag.pointerId !== ev.pointerId || drag.dragging) return;
          drag.armed = true;
          drag.card.classList.add('is-armed');
        }, drag.holdMs);
      };

      const onPointerMove = (ev) => {
        edge.mouseX = ev.clientX;
        edge.mouseY = ev.clientY;

        if (pan.active && ev.pointerId === pan.pointerId) {
          state.panX = pan.startPanX + (ev.clientX - pan.startX);
          state.panY = pan.startPanY + (ev.clientY - pan.startY);
          render();
          return;
        }

        if (!drag.mayDrag || !drag.card || ev.pointerId !== drag.pointerId) return;

        const dx = ev.clientX - drag.startClientX;
        const dy = ev.clientY - drag.startClientY;
        const dist = Math.hypot(dx, dy);

        if (!drag.armed) {
          // Move-before-hold is treated as click/text-select intent, not drag.
          if (dist > 6) resetDragState();
          return;
        }

        if (!drag.dragging && dist < 2) return;

        if (!drag.dragging) {
          clearHoldTimer();
          drag.dragging = true;
          drag.wasDragging = true;
          drag.card.setPointerCapture(ev.pointerId);
          root.classList.add('is-dragging-card');
          drag.card.classList.remove('is-armed');
          drag.card.classList.add('is-dragging');
        }

        ev.preventDefault();

        const worldX = (ev.clientX - state.panX) / state.scale;
        const worldY = (ev.clientY - state.panY) / state.scale;
        const nextX = snap(drag.startX + (worldX - drag.startWorldX));
        const nextY = snap(drag.startY + (worldY - drag.startWorldY));
        setCardPos(drag.card, nextX, nextY);
      };

      const endCardDrag = () => {
        if (!drag.card) return;
        if (drag.dragging) {
          const finalX = snap(parseNum(drag.card.dataset.x));
          const finalY = snap(parseNum(drag.card.dataset.y));
          setCardPos(drag.card, finalX, finalY);
        }
        resetDragState();
      };

      const onPointerUp = (ev) => {
        if (pan.active && ev.pointerId === pan.pointerId) {
          pan.active = false;
          pan.pointerId = -1;
          pan.middlePressed = false;
        }

        if (drag.mayDrag && ev.pointerId === drag.pointerId) {
          endCardDrag();
        }
      };

      const onWheel = (ev) => {
        ev.preventDefault();

        if (pan.middlePressed) {
          return;
        }

        const beforeX = (ev.clientX - state.panX) / state.scale;
        const beforeY = (ev.clientY - state.panY) / state.scale;

        const zoomFactor = Math.exp(-ev.deltaY * 0.00035);
        const nextScale = clampScale(state.scale * zoomFactor);
        state.scale = nextScale;
        state.panX = ev.clientX - beforeX * nextScale;
        state.panY = ev.clientY - beforeY * nextScale;

        render();
      };

      viewport.addEventListener('pointerdown', (ev) => {
        if (ev.button === 1) {
          ev.preventDefault();
          pan.active = true;
          pan.pointerId = ev.pointerId;
          pan.startX = ev.clientX;
          pan.startY = ev.clientY;
          pan.startPanX = state.panX;
          pan.startPanY = state.panY;
          pan.middlePressed = true;
          viewport.setPointerCapture(ev.pointerId);
          return;
        }

        onCardDown(ev);
      });

      viewport.addEventListener('pointermove', onPointerMove, { passive: false });
      viewport.addEventListener('pointerup', onPointerUp);
      viewport.addEventListener('pointercancel', onPointerUp);
      viewport.addEventListener('click', (ev) => {
        if (drag.wasDragging) {
          ev.preventDefault();
          ev.stopPropagation();
          drag.wasDragging = false;
        }
      }, { capture: true });
      viewport.addEventListener('wheel', onWheel, { passive: false });
      viewport.addEventListener('dragstart', (ev) => ev.preventDefault());
      viewport.addEventListener('mouseenter', () => {
        edge.active = true;
      });
      viewport.addEventListener('mousemove', (ev) => {
        edge.mouseX = ev.clientX;
        edge.mouseY = ev.clientY;
      });
      viewport.addEventListener('mouseleave', () => {
        edge.active = false;
      });
      window.addEventListener(
        'mouseup',
        (ev) => {
          if (ev.button === 1) {
            pan.middlePressed = false;
          }
        },
        { capture: true },
      );

      window.addEventListener('resize', () => {
        cards.forEach(refreshCardMetrics);
      });
      window.addEventListener('load', () => {
        cards.forEach(refreshCardMetrics);
      });

      const edgeScroll = () => {
        if (edge.active) {
          const rect = viewport.getBoundingClientRect();
          const localX = edge.mouseX - rect.left;
          const localY = edge.mouseY - rect.top;
          let dx = 0;
          let dy = 0;

          if (localX >= 0 && localX <= rect.width && localY >= 0 && localY <= rect.height) {
            if (localX < edge.threshold) dx = edge.speed;
            if (localX > rect.width - edge.threshold) dx = -edge.speed;
            if (localY < edge.threshold) dy = edge.speed;
            if (localY > rect.height - edge.threshold) dy = -edge.speed;
          }

          if (dx !== 0 || dy !== 0) {
            state.panX += dx;
            state.panY += dy;
            render();
          }
        }

        window.requestAnimationFrame(edgeScroll);
      };

      render();
      window.requestAnimationFrame(edgeScroll);
    })();
  </script>
</BaseLayout>
