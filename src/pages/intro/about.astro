---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAboutCards } from '../../domain/about/queries';
import '../../styles/components/pages/about.scss';

const cards = await getAboutCards();
const renderedCards = await Promise.all(
  cards.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<BaseLayout title="About - Volleier" showNav={false} showFooter={false}>
  <main class="about-container" data-grid-size="24">
    <div class="canvas-viewport" id="about-canvas">
      <div class="dot-grid-layer"></div>

      <div class="canvas-content" id="about-canvas-content">
        {renderedCards.map(({ entry, Content }) => (
          <article
            class:list={['info-card', 'about-card', entry.data.className]}
            data-card
            data-x={entry.data.x}
            data-y={entry.data.y}
            data-init-x={entry.data.x}
            data-init-y={entry.data.y}
            style={`--card-grid-w:${entry.data.w};`}
          >
            <div class:list={['card-accent', entry.data.accent]}></div>
            <header class="card-header">
              <span class="tag">{entry.data.tag}</span>
              <h2>{entry.data.heading}</h2>
            </header>
            <div class="card-body markdown-body">
              <Content />
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="serif serif-top"></div>
    <div class="serif serif-bottom">
      <div class="canvas-controls">
        <a href="/" class="ctrl-btn btn-return">
          <span class="ctrl-icon"><svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg></span>
          <span class="ctrl-label">RETURN</span>
        </a>
        <button id="btn-zoom-fit" class="ctrl-btn btn-fit">
          <span class="ctrl-icon"><svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M3 3h18v18H3V3m2 2v14h14V5H5m2 2h4v2H7v2H5V7h2m12 10h-4v-2h4v-2h2v4h-2M7 17v-4h2v2h2v2H7m12-10h-4v2h2v2h2V7z"/></svg></span>
          <span class="ctrl-label">FIT</span>
        </button>
        <button id="btn-focus" class="ctrl-btn btn-focus">
          <span class="ctrl-icon"><svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg></span>
          <span class="ctrl-label">FOCUS</span>
        </button>
        <button id="btn-view-reset" class="ctrl-btn btn-reset">
          <span class="ctrl-icon"><svg viewBox="0 0 24 24" width="18" height="18"><path fill="currentColor" d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/></svg></span>
          <span class="ctrl-label">RESET</span>
        </button>
      </div>
    </div>
    <div class="serif serif-left"></div>
    <div class="serif serif-right"></div>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('.about-container');
      const viewport = document.getElementById('about-canvas');
      const canvas = document.getElementById('about-canvas-content');
      if (!root || !viewport || !canvas) return;

      const gridSize = Number(root.dataset.gridSize || 24);
      const cards = Array.from(canvas.querySelectorAll('[data-card]'));
      const state = {
        panX: 0,
        panY: 0,
        scale: 1,
      };

      const edge = {
        active: false,
        mouseX: 0,
        mouseY: 0,
        threshold: 72,
        speed: 18,
      };

      const drag = {
        card: null,
        pointerId: -1,
        startClientX: 0,
        startClientY: 0,
        startWorldX: 0,
        startWorldY: 0,
        startX: 0,
        startY: 0,
        dragging: false,
        mayDrag: false,
        armed: false,
        holdMs: 160,
        holdTimer: null,
        wasDragging: false,
      };

      const pan = {
        active: false,
        pointerId: -1,
        startX: 0,
        startY: 0,
        startPanX: 0,
        startPanY: 0,
        middlePressed: false,
      };

      const snap = (value) => Math.round(value / gridSize) * gridSize;
      const clampScale = (v) => Math.min(2.4, Math.max(0.45, v));

      const parseNum = (value, fallback = 0) => {
        const n = Number(value);
        return Number.isFinite(n) ? n : fallback;
      };

      const setCardPos = (card, x, y) => {
        card.dataset.x = String(x);
        card.dataset.y = String(y);
        card.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      };

      const refreshCardMetrics = (card) => {
        const width = Math.max(gridSize * 8, Math.ceil(card.offsetWidth / gridSize) * gridSize);
        const height = Math.max(gridSize * 8, Math.ceil(card.scrollHeight / gridSize) * gridSize);
        card.style.width = `${width}px`;
        card.style.minHeight = `${height}px`;
      };

      const getCardRect = (card) => {
        const x = parseNum(card.dataset.x);
        const y = parseNum(card.dataset.y);
        const w = card.offsetWidth;
        const h = card.offsetHeight;
        return { x, y, w, h, cx: x + w / 2, cy: y + h / 2 };
      };

      const resolveCollisions = (movedCard, startX, startY) => {
        let iterations = 0;
        const maxIterations = 60;
        let hasCollision = true;

        let curX = startX;
        let curY = startY;
        const w = movedCard.offsetWidth;
        const h = movedCard.offsetHeight;

        while (hasCollision && iterations < maxIterations) {
          hasCollision = false;
          iterations++;

          const r1 = {
            x: curX,
            y: curY,
            w,
            h,
            cx: curX + w / 2,
            cy: curY + h / 2
          };

          for (const other of cards) {
            if (other === movedCard) continue;
            
            const ox = parseNum(other.dataset.x);
            const oy = parseNum(other.dataset.y);
            const r2 = {
              x: ox,
              y: oy,
              w: other.offsetWidth,
              h: other.offsetHeight,
              cx: ox + other.offsetWidth / 2,
              cy: oy + other.offsetHeight / 2
            };

            // Intersection check (AABB)
            if (
              r1.x < r2.x + r2.w &&
              r1.x + r1.w > r2.x &&
              r1.y < r2.y + r2.h &&
              r1.y + r1.h > r2.y
            ) {
              hasCollision = true;
              const dx = r1.cx - r2.cx;
              const dy = r1.cy - r2.cy;

              // Dominant axis displacement: Push to the nearest edge
              if (Math.abs(dx) / r1.w >= Math.abs(dy) / r1.h) {
                // Horizontal push
                if (dx >= 0) {
                  curX = r2.x + r2.w + gridSize; // Move to right edge
                } else {
                  curX = r2.x - r1.w - gridSize; // Move to left edge
                }
              } else {
                // Vertical push
                if (dy >= 0) {
                  curY = r2.y + r2.h + gridSize; // Move to bottom edge
                } else {
                  curY = r2.y - r1.h - gridSize; // Move to top edge
                }
              }
              
              curX = snap(curX);
              curY = snap(curY);
              // Restart checking all cards from the new position
              break; 
            }
          }
        }
        return { x: curX, y: curY };
      };

      const render = () => {
        root.style.setProperty('--pan-x', `${state.panX}`);
        root.style.setProperty('--pan-y', `${state.panY}`);
        root.style.setProperty('--zoom', `${state.scale}`);
        canvas.style.transform = `translate3d(${state.panX}px, ${state.panY}px, 0) scale(${state.scale})`;
      };

      cards.forEach((card) => {
        refreshCardMetrics(card);
        const x = snap(parseNum(card.dataset.x));
        const y = snap(parseNum(card.dataset.y));
        setCardPos(card, x, y);
      });

      const clearHoldTimer = () => {
        if (drag.holdTimer !== null) {
          window.clearTimeout(drag.holdTimer);
          drag.holdTimer = null;
        }
      };

      const resetDragState = () => {
        clearHoldTimer();
        if (drag.card) {
          if (drag.pointerId !== -1 && drag.card.hasPointerCapture(drag.pointerId)) {
            drag.card.releasePointerCapture(drag.pointerId);
          }
          drag.card.classList.remove('is-armed');
          drag.card.classList.remove('is-dragging');
        }
        root.classList.remove('is-dragging-card');
        drag.pointerId = -1;
        drag.dragging = false;
        drag.mayDrag = false;
        drag.armed = false;
        // drag.card cleanup is now handled in endCardDrag to allow animation to complete.
      };

      const onCardDown = (ev) => {
        const target = ev.target;
        if (!(target instanceof HTMLElement)) return;
        if (ev.button !== 0) return;

        const card = target.closest('[data-card]');
        if (!card || !(card instanceof HTMLElement)) return;

        if (state.focusMode) {
          focusOnCard(card);
          return;
        }

        drag.card = card;
        drag.pointerId = ev.pointerId;
        drag.startClientX = ev.clientX;
        drag.startClientY = ev.clientY;
        drag.startWorldX = (ev.clientX - state.panX) / state.scale;
        drag.startWorldY = (ev.clientY - state.panY) / state.scale;
        drag.startX = parseNum(card.dataset.x);
        drag.startY = parseNum(card.dataset.y);
        drag.dragging = false;
        drag.mayDrag = true;
        drag.armed = false;
        drag.wasDragging = false;

        // Note: card.setPointerCapture is moved to onPointerMove to avoid interfering with 'click' events for links.

        drag.holdTimer = window.setTimeout(() => {
          if (!drag.mayDrag || !drag.card || drag.pointerId !== ev.pointerId || drag.dragging) return;
          drag.armed = true;
          drag.card.classList.add('is-armed');
        }, drag.holdMs);
      };

      const onPointerMove = (ev) => {
        edge.mouseX = ev.clientX;
        edge.mouseY = ev.clientY;

        if (pan.active && ev.pointerId === pan.pointerId) {
          state.panX = pan.startPanX + (ev.clientX - pan.startX);
          state.panY = pan.startPanY + (ev.clientY - pan.startY);
          render();
          return;
        }

        if (!drag.mayDrag || !drag.card || ev.pointerId !== drag.pointerId) return;

        const dx = ev.clientX - drag.startClientX;
        const dy = ev.clientY - drag.startClientY;
        const dist = Math.hypot(dx, dy);

        if (!drag.armed) {
          // Move-before-hold is treated as click/text-select intent, not drag.
          if (dist > 6) resetDragState();
          return;
        }

        if (!drag.dragging && dist < 2) return;

        if (!drag.dragging) {
          clearHoldTimer();
          drag.dragging = true;
          drag.wasDragging = true;
          drag.card.setPointerCapture(ev.pointerId);
          root.classList.add('is-dragging-card');
          drag.card.classList.remove('is-armed');
          drag.card.classList.add('is-dragging');
        }

        ev.preventDefault();

        const worldX = (ev.clientX - state.panX) / state.scale;
        const worldY = (ev.clientY - state.panY) / state.scale;
        const nextX = snap(drag.startX + (worldX - drag.startWorldX));
        const nextY = snap(drag.startY + (worldY - drag.startWorldY));
        setCardPos(drag.card, nextX, nextY);
      };

      const endCardDrag = () => {
        const card = drag.card;
        if (!card) return;

        if (drag.dragging) {
          const dropX = snap(parseNum(card.dataset.x));
          const dropY = snap(parseNum(card.dataset.y));

          // 1. Simulate final position until clear
          const finalPos = resolveCollisions(card, dropX, dropY);

          // 2. Clear dragging classes first (re-enables CSS transition)
          resetDragState();

          // 3. Apply position in next frame to trigger animation
          requestAnimationFrame(() => {
            setCardPos(card, finalPos.x, finalPos.y);
            
            // Visual feedback: brief z-index boost during animation
            card.style.zIndex = '50';
            setTimeout(() => { 
              if(card) card.style.zIndex = ''; 
            }, 600);
          });
        } else {
          resetDragState();
        }
        drag.card = null;
      };

      const onPointerUp = (ev) => {
        if (pan.active && ev.pointerId === pan.pointerId) {
          pan.active = false;
          pan.pointerId = -1;
          pan.middlePressed = false;
        }

        if (drag.mayDrag && ev.pointerId === drag.pointerId) {
          endCardDrag();
        }
      };

      const onWheel = (ev) => {
        ev.preventDefault();

        if (pan.middlePressed) {
          return;
        }

        const beforeX = (ev.clientX - state.panX) / state.scale;
        const beforeY = (ev.clientY - state.panY) / state.scale;

        const zoomFactor = Math.exp(-ev.deltaY * 0.00035);
        const nextScale = clampScale(state.scale * zoomFactor);
        state.scale = nextScale;
        state.panX = ev.clientX - beforeX * nextScale;
        state.panY = ev.clientY - beforeY * nextScale;

        render();
      };

      viewport.addEventListener('pointerdown', (ev) => {
        if (ev.button === 1) {
          ev.preventDefault();
          pan.active = true;
          pan.pointerId = ev.pointerId;
          pan.startX = ev.clientX;
          pan.startY = ev.clientY;
          pan.startPanX = state.panX;
          pan.startPanY = state.panY;
          pan.middlePressed = true;
          viewport.setPointerCapture(ev.pointerId);
          return;
        }

        onCardDown(ev);
      });

      viewport.addEventListener('pointermove', onPointerMove, { passive: false });
      viewport.addEventListener('pointerup', onPointerUp);
      viewport.addEventListener('pointercancel', onPointerUp);
      viewport.addEventListener('click', (ev) => {
        if (drag.wasDragging) {
          ev.preventDefault();
          ev.stopPropagation();
          drag.wasDragging = false;
        }
      }, { capture: true });
      viewport.addEventListener('wheel', onWheel, { passive: false });
      viewport.addEventListener('dragstart', (ev) => ev.preventDefault());
      viewport.addEventListener('mouseenter', () => {
        edge.active = true;
      });
      viewport.addEventListener('mousemove', (ev) => {
        edge.mouseX = ev.clientX;
        edge.mouseY = ev.clientY;
      });
      viewport.addEventListener('mouseleave', () => {
        edge.active = false;
      });
      window.addEventListener(
        'mouseup',
        (ev) => {
          if (ev.button === 1) {
            pan.middlePressed = false;
          }
        },
        { capture: true },
      );

      window.addEventListener('resize', () => {
        cards.forEach(refreshCardMetrics);
      });
      window.addEventListener('load', () => {
        cards.forEach(refreshCardMetrics);
      });

      // Viewport Control Handlers
      const btnReset = document.getElementById('btn-view-reset');
      const btnFit = document.getElementById('btn-zoom-fit');
      const btnFocus = document.getElementById('btn-focus');

      if (btnReset) {
        btnReset.addEventListener('click', () => {
          canvas.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
          
          // Reset card positions to initial
          cards.forEach(card => {
            const ix = parseNum(card.dataset.initX);
            const iy = parseNum(card.dataset.initY);
            setCardPos(card, ix, iy);
          });

          state.panX = 0;
          state.panY = 0;
          state.scale = 1;
          
          // Deactivate focus mode if active
          if (state.focusMode) {
            state.focusMode = false;
            root.classList.remove('is-focus-mode');
            if (btnFocus) btnFocus.classList.remove('is-active');
          }

          render();
          setTimeout(() => { canvas.style.transition = ''; }, 800);
        });
      }

      if (btnFit) {
        btnFit.addEventListener('click', () => {
          if (cards.length === 0) return;

          let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
          
          cards.forEach(card => {
            const x = parseNum(card.dataset.x);
            const y = parseNum(card.dataset.y);
            const w = card.offsetWidth;
            const h = card.offsetHeight;
            
            minX = Math.min(minX, x);
            minY = Math.min(minY, y);
            maxX = Math.max(maxX, x + w);
            maxY = Math.max(maxY, y + h);
          });

          const contentW = maxX - minX;
          const contentH = maxY - minY;
          const padding = 120;
          
          const availableW = window.innerWidth - padding;
          const availableH = window.innerHeight - padding;
          
          const targetScale = Math.min(availableW / contentW, availableH / contentH, 1.2);
          const finalScale = Math.max(targetScale, 0.4);

          canvas.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
          state.scale = finalScale;
          state.panX = (window.innerWidth - contentW * state.scale) / 2 - minX * state.scale;
          state.panY = (window.innerHeight - contentH * state.scale) / 2 - minY * state.scale;
          
          render();
          setTimeout(() => { canvas.style.transition = ''; }, 800);
        });
      }

      if (btnFocus) {
        btnFocus.addEventListener('click', () => {
          state.focusMode = !state.focusMode;
          btnFocus.classList.toggle('is-active', state.focusMode);
          root.classList.toggle('is-focus-mode', state.focusMode);
        });
      }

      const focusOnCard = (card) => {
        const rect = getCardRect(card);
        // Occupy roughly 45% of screen width to ensure >1/3 coverage
        const targetW = window.innerWidth * 0.45;
        const targetScale = Math.min(targetW / rect.w, 1.8);
        const finalScale = Math.max(targetScale, 1);

        canvas.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
        state.scale = finalScale;
        state.panX = window.innerWidth / 2 - rect.cx * state.scale;
        state.panY = window.innerHeight / 2 - rect.cy * state.scale;
        render();
        setTimeout(() => { canvas.style.transition = ''; }, 800);
      };

      const edgeScroll = () => {
        if (edge.active) {
          const rect = viewport.getBoundingClientRect();
          const localX = edge.mouseX - rect.left;
          const localY = edge.mouseY - rect.top;
          let dx = 0;
          let dy = 0;

          if (localX >= 0 && localX <= rect.width && localY >= 0 && localY <= rect.height) {
            if (localX < edge.threshold) dx = edge.speed;
            if (localX > rect.width - edge.threshold) dx = -edge.speed;
            if (localY < edge.threshold) dy = edge.speed;
            if (localY > rect.height - edge.threshold) dy = -edge.speed;
          }

          if (dx !== 0 || dy !== 0) {
            state.panX += dx;
            state.panY += dy;
            render();
          }
        }

        window.requestAnimationFrame(edgeScroll);
      };

      render();
      window.requestAnimationFrame(edgeScroll);
    })();
  </script>
</BaseLayout>
