---
import { render } from 'astro:content';
import BaseLayout from '../../components/ui/layout/BaseLayout.astro';
import { getAllWikiPages, getWikiPageBySlug } from '../../domain/wiki/queries';
import { formatDate } from '../../domain/shared/date';

export async function getStaticPaths() {
  const pages = await getAllWikiPages();
  return pages.map((entry: any) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
const entry = await getWikiPageBySlug(slug as string);
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-8">
    <aside class="md:w-64 flex-shrink-0 order-2 md:order-1 pt-8">
       <div class="sticky top-24 glass-card p-6 rounded-2xl">
         <h3 class="font-outfit font-bold text-lg mb-4 text-indigo-600 dark:text-indigo-400">Wiki Meta</h3>
         <ul class="text-sm space-y-3 text-slate-600 dark:text-slate-400">
           <li><strong>Category:</strong> {entry.data.category}</li>
           <li><strong>Last Updated:</strong> {formatDate(entry.data.lastUpdated)}</li>
         </ul>
         <div class="mt-6 pt-6 border-t border-slate-200 dark:border-slate-800">
           <a href="/wiki" class="text-sm text-blue-500 hover:underline flex items-center">
             ← Back to Wiki Index
           </a>
         </div>
       </div>
    </aside>
    <main class="flex-grow order-1 md:order-2 pt-8">
      <article class="prose prose-slate dark:prose-invert prose-headings:font-outfit max-w-none">
        <h1 class="text-4xl font-bold mb-8">{entry.data.title}</h1>
        <div class="pt-6 border-t border-slate-200 dark:border-slate-800">
          <Content />
        </div>
      </article>
    </main>
  </div>
</BaseLayout>
