---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WikiList from '../../components/ui/wiki/WikiList.astro';
import { getAllWikiPages } from '../../domain/wiki/queries';

const pages = await getAllWikiPages();
---

<BaseLayout title="Wiki" description="Wiki 索引">
  <main class="max-w-4xl mx-auto py-8 px-4">
    <h1 class="sr-only">Wiki</h1>
    <WikiList pages={pages} />
  </main>
</BaseLayout>
