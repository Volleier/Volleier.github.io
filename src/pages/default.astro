---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/default.scss';
---
<BaseLayout showNav={false} showFooter={false}>
  <main class="index-container">
    <!-- Decorative Serifs -->
    <div class="serif serif-top"></div>
    <div class="serif serif-bottom"></div>
    <div class="serif serif-left"></div>
    <div class="serif serif-right"></div>

    <div class="content-wrapper">
      <!-- Centered Logo -->
      <div class="logo-area">
        <img 
          src="/assets/default/PengLaiSiShaoXiao-Logo.png" 
          alt="PengLaiSiShaoXiao Logo" 
          class="main-logo"
        />
      </div>

      <!-- Industrial Buttons Container -->
      <div class="button-group">
        <a href="#" class="tech-button">
          <span class="tech-tag">CMD_01</span>
          <span class="tech-label">个人作品集</span>
          <div class="tech-accent"></div>
        </a>
        <a href="/about" class="tech-button">
          <span class="tech-tag">CMD_02</span>
          <span class="tech-label">介绍</span>
          <div class="tech-accent"></div>
        </a>
        <a href="#" class="tech-button">
          <span class="tech-tag">CMD_03</span>
          <span class="tech-label">架空世界观</span>
          <div class="tech-accent"></div>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
