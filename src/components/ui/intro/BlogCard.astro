---
import { formatDate } from '../../../domain/shared/date';
const { post } = Astro.props;
---

<article class="glass-card p-6 rounded-xl">
  <a href={`/intro/${post.id}`} class="text-2xl font-bold text-indigo-600 hover:underline">{post.data.title}</a>
  {post.data.description ? <p class="mt-2 text-slate-600">{post.data.description}</p> : null}
  <div class="mt-4 text-sm text-slate-500">
    <span>{formatDate(post.data.publishDate)}</span>
    {post.data.author ? <span> · {post.data.author}</span> : null}
  </div>
</article>

