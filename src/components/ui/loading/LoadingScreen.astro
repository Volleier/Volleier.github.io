---
import GildedEffect from '../effects/GildedEffect.astro';
import '../../../styles/components/loading-screen.scss';
---

<div id="loading-screen" class="loading-overlay">
    <!-- Hexagonal Background Grid -->
    <div class="hex-grid-container"></div>

    <!-- Rich Background Decorations -->
    <div class="hud-decorations">
      <!-- 1. Corner Brackets -->
      <div class="hud-bracket top-left"></div>
      <div class="hud-bracket bottom-right"></div>
      
      <!-- 2. Warning Tape -->
      <div class="hud-warning-tape"></div>
      
      <!-- 3. Giant Outline Circles / Radars -->
      <div class="hud-circle-large"></div>
      <div class="hud-circle-small"></div>
      
      <!-- 4. System Boot Data Text -->
      <div class="hud-data-column">
        <div>SYS.INITIALIZATION</div>
        <div>V_CORE_LOAD: TRUE</div>
        <div>MEMORY_CHECK... OK</div>
        <div>OVERRIDE_AUTH: PENDING</div>
        <div>AWAITING_INPUT_SEC</div>
      </div>
      
      <!-- 5. Dotted Technical Grid Patches -->
      <div class="hud-dot-grid"></div>
      
      <!-- 6. Target Crosshairs -->
      <div class="hud-crosshair center-left"></div>
      <div class="hud-crosshair bottom-center"></div>

      <!-- 7. Abstract Vertical Barcodes / Rectangles -->
      <div class="hud-barcode"></div>
    </div>
    
    <!-- Background Decorative Lines -->
    <div class="decor-line h-line-top"></div>
    <div class="decor-line v-line-right"></div>
    
    <!-- Status Bar Area (Bottom) -->
    <div class="status-bar-container">
        <div class="loading-bar">
            <!-- Gilded Effect Overlay (Contained) -->
            <GildedEffect zIndex={1} />
        </div>
        <div class="magenta-line"></div>
    </div>

    <!-- Badge Logo (Massive Scale) -->
    <div class="badge-container">
        <!-- Colored Accent Layer (Linear Burn Effect) -->
        <div class="badge-accent"></div>
        <img src="/assets/loading/Volleier-Logo.png" alt="Badge Logo" class="badge-img" />
    </div>

    <!-- Name Block (Top Right - Complex Geometry) -->
    <div class="name-block-outer">
        <div class="name-block-container">
            <div class="accent-squares">
                <div class="square hollow"></div>
                <!-- Extra Large Pink Square -->
                <div class="square solid-magenta large-square"></div>
            </div>
            <div class="name-content">
                <div class="trapezoid-bg"></div>
                <div class="name-images">
                    <img src="/assets/loading/PengLaiSiShaoXiao.png" alt="蓬莱寺劭鸮" class="name-zh" />
                    <!-- Broken White Line -->
                    <div class="white-separator-container">
                        <div class="white-separator"></div>
                    </div>
                    <img src="/assets/loading/Volleier.png" alt="Volleier" class="name-en" />
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function startLoadingTimer() {
        const loadingScreen = document.getElementById('loading-screen');
        if (!loadingScreen) return;

        setTimeout(() => {
            loadingScreen.classList.add('fade-out');
            setTimeout(() => {
                loadingScreen.style.display = 'none';
            }, 800);
        }, 3000);
    }

    startLoadingTimer();
</script>
